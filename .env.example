# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost

# Mirrors for Iran-friendly local development
DOCKER_REGISTRY=docker.arvancloud.ir
DOCKER_OFFICIAL_NAMESPACE=library
PIP_INDEX_URL=https://pypi.org/simple
NPM_REGISTRY=https://registry.npmjs.org/

# External PostgreSQL, per architecture.md
DATABASE_URL=postgresql://drgame:drgame-password@postgres.example.com:5432/drgame

# Redis / Channels / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Next.js
NEXT_PUBLIC_API_BASE_URL=/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost/ws
